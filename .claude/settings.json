{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Task",
      "Glob",
      "Grep",
      "Bash(*)",
      "Agent(*)",
      "Skill(*)",
      "Skill(*:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(*rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git rebase*)",
      "Bash(git clean -f*)",
      "Bash(docker system prune*)",
      "Bash(*DROP TABLE*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DELETE FROM*)",
      "Bash(chmod 777*)",
      "Bash(*mkfs*)",
      "Bash(*format [A-Z]:*)",
      "Bash(*del /s*)",
      "Bash(*del /S*)"
    ]
  },
  "model": "sonnet",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6"
  },
  "enabledPlugins": {
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "auto-ops@automationone-local": true
  },
  "context": {
    "alwaysInclude": [
      ".claude/claude.md"
    ],
    "maxTokens": 200000
  },
  "skills": {
    "directory": ".claude/skills",
    "autoLoad": true
  },
  "taskManagement": {
    "enabled": true,
    "autoTrack": true
  },
  "testing": {
    "esp32": {
      "framework": "platformio",
      "location": "El Trabajante/tests/",
      "command": "cd \"El Trabajante\" && pio test"
    },
    "server": {
      "framework": "pytest",
      "location": "El Servador/god_kaiser_server/tests/",
      "command": "cd \"El Servador/god_kaiser_server\" && .venv/Scripts/pytest.exe -v --tb=short --no-cov"
    },
    "wokwi": {
      "framework": "wokwi-cli",
      "location": "El Trabajante/tests/wokwi/",
      "command": "cd \"El Trabajante\" && wokwi-cli . --timeout 90000 --serial-log-file wokwi.log"
    }
  },
  "build": {
    "esp32": {
      "environments": [
        "seeed_xiao_esp32c3",
        "esp32_dev",
        "wokwi_simulation"
      ],
      "defaultEnvironment": "esp32_dev",
      "command": "cd \"El Trabajante\" && pio run -e"
    },
    "server": {
      "command": "cd \"El Servador/god_kaiser_server\" && .venv/Scripts/pip.exe install -e ."
    },
    "frontend": {
      "command": "cd \"El Frontend\" && npm install && npm run build"
    }
  },
  "run": {
    "server": {
      "command": "cd \"El Servador/god_kaiser_server\" && .venv/Scripts/python.exe -m uvicorn src.main:app --reload --host 0.0.0.0 --port 8000"
    },
    "frontend": {
      "command": "cd \"El Frontend\" && npm run dev"
    }
  },
  "git": {
    "autoCommit": false,
    "commitMessageTemplate": "<type>(<scope>): <subject>\n\n<body>",
    "requireTests": false,
    "conventionalCommits": true
  },
  "paths": {
    "esp32": "El Trabajante",
    "server": "El Servador/god_kaiser_server",
    "frontend": "El Frontend",
    "docs": {
      "esp32": "El Trabajante/docs",
      "server": "El Servador/docs",
      "frontend": "El Frontend/Docs",
      "mqtt": "El Trabajante/docs/Mqtt_Protocoll.md",
      "skills": ".claude/skills",
      "reference": ".claude/reference",
      "rules": ".claude/rules"
    }
  },
  "autoops": {
    "serverUrl": "http://localhost:8000",
    "plugins": "El Servador/god_kaiser_server/src/autoops/plugins/",
    "reports": "El Servador/god_kaiser_server/src/autoops/reports/",
    "documentation": ".claude/CLAUDE_AUTOOPS.md"
  },
  "workflows": {
    "preCommit": [
      "/full-test"
    ],
    "afterESP32Change": [
      "/esp-build",
      "/esp-test"
    ],
    "afterServerChange": [
      "/server-test",
      "/esp-test"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-format.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Bevor du stoppst: Pruefe ob alle TodoWrite-Tasks als completed markiert sind und ob die Verifikationskriterien (Build/Test/Lint) fuer alle geaenderten Bereiche erfolgreich waren. Falls nicht, arbeite weiter."
          }
        ]
      }
    ]
  }
}
