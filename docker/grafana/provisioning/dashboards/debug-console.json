{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "uid": "debug-console",
  "title": "Debug Console",
  "description": "Active debugging dashboard — Error rates, log streams, correlation tracing. First stop for every debug session.",
  "tags": ["debug", "loki", "logs"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "custom",
        "current": { "text": "all", "value": ".+" },
        "options": [
          { "text": "all", "value": ".+", "selected": true },
          { "text": "el-servador", "value": "el-servador", "selected": false },
          { "text": "el-frontend", "value": "el-frontend", "selected": false },
          { "text": "mqtt-broker", "value": "mqtt-broker", "selected": false },
          { "text": "postgres", "value": "postgres", "selected": false },
          { "text": "esp32-serial-logger", "value": "esp32-serial-logger", "selected": false }
        ],
        "query": "all : .+, el-servador : el-servador, el-frontend : el-frontend, mqtt-broker : mqtt-broker, postgres : postgres, esp32-serial-logger : esp32-serial-logger"
      },
      {
        "name": "search",
        "label": "Freitext-Suche",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "correlation_id",
        "label": "Correlation-ID",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      },
      {
        "name": "error_code",
        "label": "Error-Code",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "title": "Error Rate (5min)",
      "description": "Total errors across all services in the last 5 minutes",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(count_over_time({compose_service=~\".+\"} | level=\"ERROR\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Errors by Service",
      "description": "Error distribution across services for the selected time range",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (compose_service) (count_over_time({compose_service=~\".+\"} | level=\"ERROR\" [$__range]))",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "ESP Device Status",
      "description": "Last heartbeat time for registered ESP32 devices",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "automationone_esp_last_heartbeat_seconds",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Last Heartbeat (s)" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true }
          }
        }
      ]
    },
    {
      "title": "Error Log Stream",
      "description": "Live stream of ERROR-level logs from all services",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "{compose_service=~\".+\"} | level=\"ERROR\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Full Log Stream (filtered)",
      "description": "Log stream filtered by service and free-text search. Use the Service and Freitext-Suche variables.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 24 },
      "id": 5,
      "targets": [
        {
          "expr": "{compose_service=~\"$service\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Correlation Trace",
      "description": "Cross-service log trace by Correlation-ID. Enter a request_id or correlation_id in the variable.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 40 },
      "id": 6,
      "targets": [
        {
          "expr": "{compose_service=~\".+\"} |= \"$correlation_id\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Ascending",
        "dedupStrategy": "none"
      }
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "version": 1
}
