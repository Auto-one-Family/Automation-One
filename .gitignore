# ==========================================
# AutomationOne .gitignore
# ==========================================

# ========== GLOBAL ==========
.DS_Store
.AppleDouble
.LSOverride
*~
.Trash-*
Thumbs.db
ehthumbs.db
Desktop.ini
nul
**/nul
.vscode/
.idea/
*.swp
*.swo
*.swn
*.log
npm-debug.log*

# ========== DEBUG LOGS ==========
# Log-Inhalte ignorieren, aber Struktur behalten
logs/current/*
!logs/current/.gitkeep
logs/archive/*
!logs/archive/.gitkeep
logs/postgres/*
!logs/postgres/.gitkeep
logs/mqtt/*
!logs/mqtt/.gitkeep
logs/server/*.log*
!logs/server/.gitkeep
!logs/README.md
yarn-debug.log*
*.tmp
*.temp
.cache/

# ========== ESP32 (El Trabajante) ==========
El\ Trabajante/.pio/
El\ Trabajante/.vscode/
El\ Trabajante/build/
El\ Trabajante/.pio
El\ Trabajante/platformio.ini.bak
El\ Trabajante/*.bin
El\ Trabajante/*.elf
El\ Trabajante/.pioenvs
El\ Trabajante/.piolibdeps

# ========== SERVER (El Servador) ==========
El\ Servador/__pycache__/
El\ Servador/*.py[cod]
El\ Servador/*$py.class
El\ Servador/.Python
El\ Servador/env/
El\ Servador/venv/
El\ Servador/ENV/
El\ Servador/.venv
El\ Servador/pip-log.txt
El\ Servador/pip-delete-this-directory.txt
El\ Servador/.pytest_cache/
El\ Servador/.coverage
El\ Servador/htmlcov/
El\ Servador/dist/
El\ Servador/build/
El\ Servador/eggs/
El\ Servador/.eggs/
El\ Servador/*.egg-info/
El\ Servador/*.egg
El\ Servador/*.db
El\ Servador/*.sqlite
El\ Servador/*.sqlite3

# Environment Variables
.env
.env.local
.env.*.local
El\ Servador/.env
El\ Trabajante/.env

# Secrets & Certificates
*.key
*.pem
*.crt
!ca.crt
certificates/*.key
certificates/*.pem

# ========== DOCS ==========
docs/.vuepress/dist
docs/.vuepress/.cache
docs/.vuepress/.temp


# Backup files
El Servador/god_kaiser_server/backups/
**/backups/

# ========== DOCKER ==========
docker-compose.override.yml

# Backups
backups/*.sql.gz
backups/*.sql

# ========== BUILD ARTIFACTS ==========
debug_output.txt
El\ Frontend/coverage/
El\ Frontend/.playwright/
.playwright-mcp/
El\ Frontend/vite.config.d.ts

# ========== PYTHON CACHE ==========
scripts/__pycache__/

# ========== LOCAL SETTINGS ==========
.claude/settings.local.json

# ========== TEST ARTIFACTS ==========
logs/wokwi/reports/*.xml
logs/wokwi/reports/*.json

# Wokwi serial logs (local only)
logs/wokwi/

# ========== ROOT SCREENSHOTS ==========
/*.png

# ========== COMPILED OBJECTS ==========
El\ Trabajante/*.o

# ========== LOCAL CONFIG & ARTIFACTS ==========
.mcp.json
.claude/*.local.md
.claude/local-marketplace/
docker/**/__pycache__/
.serena/

# ========== WINDOWS INSTALLER BINARIES ==========
mosquitto-installer.exe
*.exe
ARCHIV/
growy-frontend-archive-20260224.zip
