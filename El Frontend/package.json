{
  "name": "el-frontend",
  "version": "1.0.0",
  "description": "AutomationOne Debug Dashboard - Vue 3 + TypeScript + Tailwind",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test tests/e2e/scenarios/",
    "test:css": "npx playwright test --config=playwright.css.config.ts --project=chromium",
    "test:css:all": "npx playwright test --config=playwright.css.config.ts",
    "test:css:tokens": "npx playwright test --config=playwright.css.config.ts tests/e2e/css/design-tokens.spec.ts --project=chromium",
    "test:css:visual": "npx playwright test --config=playwright.css.config.ts tests/e2e/css/visual-regression.spec.ts --project=chromium",
    "test:css:a11y": "npx playwright test --config=playwright.css.config.ts tests/e2e/css/accessibility.spec.ts tests/e2e/css/color-contrast.spec.ts --project=chromium",
    "test:css:responsive": "npx playwright test --config=playwright.css.config.ts tests/e2e/css/responsive-layout.spec.ts",
    "test:css:update-snapshots": "npx playwright test --config=playwright.css.config.ts tests/e2e/css/visual-regression.spec.ts --update-snapshots --project=chromium",
    "test:playwright": "npx playwright test",
    "test:playwright:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^10.11.1",
    "axios": "^1.10.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "date-fns": "^4.1.0",
    "gridstack": "^12.4.2",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-draggable-plus": "^0.6.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.6.1",
    "msw": "^2.12.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.2.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.0"
  }
}
