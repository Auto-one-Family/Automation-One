# AutomationOne - Environment Variables
# =====================================
# Kopiere diese Datei zu .env und passe die Werte an
# WICHTIG: .env ist in .gitignore - NIEMALS Secrets committen!

# =======================
# Docker Compose Profiles
# =======================
# Activates monitoring stack (Loki, Promtail, Prometheus, Grafana, exporters)
# by default with 'docker compose up -d'. Remove or comment out to disable.
COMPOSE_PROFILES=monitoring

# =======================
# PostgreSQL Database
# =======================
POSTGRES_USER=god_kaiser
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=god_kaiser_db

# =======================
# Database Backup (pg_dump)
# =======================
# Runs daily via el-servador scheduler (default: 02:00 UTC)
DB_BACKUP_ENABLED=true
DB_BACKUP_HOUR=2
DB_BACKUP_MINUTE=0
DB_BACKUP_PG_HOST=postgres
DB_BACKUP_PG_PORT=5432
DB_BACKUP_PG_DATABASE=god_kaiser_db
DB_BACKUP_PG_USER=god_kaiser
# Keep aligned with POSTGRES_PASSWORD unless a dedicated backup user is used.
DB_BACKUP_PG_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
# Optional: docker secret path (preferred in production).
# Example content line:
# postgres:5432:god_kaiser_db:god_kaiser:<password>
DB_BACKUP_PGPASSFILE=
DB_BACKUP_MAX_AGE_DAYS=7
DB_BACKUP_MAX_COUNT=20

# =======================
# Server (El Servador)
# =======================
# Database URL - muss zu POSTGRES_* Variablen passen
DATABASE_URL=postgresql+asyncpg://god_kaiser:CHANGE_ME_USE_STRONG_PASSWORD@postgres:5432/god_kaiser_db
DATABASE_AUTO_INIT=true

# Security - UNBEDINGT ÄNDERN FÜR PRODUCTION!
# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=true

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS - erlaubte Frontend-Origins
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =======================
# MQTT Broker (Mosquitto)
# =======================
MQTT_BROKER_HOST=mqtt-broker
MQTT_BROKER_PORT=1883
MQTT_WEBSOCKET_PORT=9001

# =======================
# Frontend (El Frontend)
# =======================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_LOG_LEVEL=debug

# =======================
# Grafana (Profile: monitoring)
# SECURITY: Change this password! Default fallback in docker-compose: 'admin' - INSECURE!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
# =======================
GRAFANA_ADMIN_PASSWORD=changeme

# =======================
# pgAdmin (Profile: devtools)
# SECURITY: Change this password! Default fallback in docker-compose: 'admin' - INSECURE!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
# =======================
PGADMIN_DEFAULT_EMAIL=admin@automationone.local
PGADMIN_DEFAULT_PASSWORD=changeme

# =======================
# Wokwi CI (Optional)
# =======================
WOKWI_CLI_TOKEN=

# =======================
# Sentry Error Tracking (Optional)
# =======================
SENTRY_AUTH_TOKEN=

# =======================
# ESP32 Serial Logger (Profile: hardware)
# =======================
# TCP-based serial bridge (ser2net/socat in WSL2)
ESP32_SERIAL_HOST=host.docker.internal
ESP32_SERIAL_PORT=3333
ESP32_DEVICE_ID=esp32-xiao-01
ESP32_LOG_FORMAT=structured
ESP32_RECONNECT_DELAY=5

# =======================
# Production Notes
# =======================
# Für Production:
# 1. Alle CHANGE_ME Werte ersetzen
# 2. ENVIRONMENT=production setzen
# 3. SERVER_RELOAD=false setzen
# 4. LOG_LEVEL=WARNING oder ERROR setzen
# 5. MQTT-Authentication aktivieren (mosquitto.conf anpassen)
# 6. HTTPS für Frontend konfigurieren
