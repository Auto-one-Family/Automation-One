# docker-compose.override.yml
# Local development override for AutomationOne.
# - Monitoring: services start without --profile (always with docker compose up -d).
# - MQTT traffic logger for debug infrastructure.
# Auto-merged by Docker Compose. Listed in .gitignore (local-only).

services:
  loki:
    profiles: []
  alloy:
    profiles: []
  prometheus:
    profiles: []
  grafana:
    profiles: []
  postgres-exporter:
    profiles: []
  mosquitto-exporter:
    profiles: []

  # MQTT Traffic Logger
  # Subscribes to kaiser/# and writes Topic + Payload to stdout.
  # Alloy scrapes stdout via Docker json-file driver -> Loki.
  # Query in Loki: {container_name="automationone-mqtt-logger"}
  mqtt-logger:
    image: eclipse-mosquitto:2
    container_name: automationone-mqtt-logger
    entrypoint: mosquitto_sub
    command: ["-h", "mqtt-broker", "-t", "kaiser/#", "-v", "-F", "%I %t %p"]
    depends_on:
      mqtt-broker:
        condition: service_healthy
    labels:
      - "automationone.service=mqtt-logger"
    logging:
      driver: json-file
      options:
        max-size: "20m"
        max-file: "5"
    networks:
      - automationone-net
    restart: unless-stopped
